{
  "name": "julian",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "quality:oxlint": "oxlint --config .oxlintrc.json --react-plugin --react-perf-plugin --jsx-a11y-plugin --vitest-plugin --deny-warnings .",
    "quality:oxfmt": "oxfmt --check .",
    "quality:fallow": "fallow dead-code",
    "quality:fp": "eslint .",
    "quality:static": "pnpm run quality:oxlint && pnpm run quality:oxfmt && pnpm run quality:fallow && pnpm run quality:fp && pnpm run typecheck",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:tz:dates": "TZ=America/Los_Angeles vitest run src/domain/date.test.ts src/domain/events.test.ts src/domain/year-grid.test.ts",
    "clean:artifacts": "rm -rf dist coverage tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@tanstack/react-router": "1.169.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "lucide-react": "1.24.0",
    "next-themes": "0.4.6",
    "radix-ui": "1.6.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-functional": "^9.0.4",
    "fallow": "2.57.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "16.4.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.62.0",
    "tailwindcss": "4.2.4",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "wrangler": "4.110.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxfmt",
      "oxlint --deny-warnings",
      "eslint"
    ]
  },
  "engines": {
    "node": "24.15.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "fallow"
    ]
  }
}
